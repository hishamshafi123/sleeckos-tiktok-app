# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production

# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-openssl-rand-hex-32

# Used by both the cron routes and the host crontab entries.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-openssl-rand-hex-32

# ── Postgres ─────────────────────────────────────────────────────────────────
# These are used by the docker-compose db service AND the DATABASE_URL below.
POSTGRES_USER=sleeckos
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=sleeckos

# DATABASE_URL is constructed automatically by docker-compose from the vars above.
# Only set this manually if running outside docker-compose (e.g. local prisma studio).
# DATABASE_URL=postgresql://sleeckos:replace-with-strong-password@db:5432/sleeckos

#── TikTok ───────────────────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── Google ───────────────────────────────────────────────────────────────────
# Full JSON content of the service account key (single line, JSON-encoded string).
GOOGLE_SERVICE_ACCOUNT_JSON=
